# Optional root-level T3 Cloud configuration for source builds. Release builds
# inject these public values at build time. Server-side secrets must never be
# committed here.
#
# T3CODE_CLERK_PUBLISHABLE_KEY=pk_test_...
# T3CODE_CLERK_CLI_OAUTH_CLIENT_ID=oauthapp_...
# T3_RELAY_URL=https://relay.example.com
